starboard = звёздоска
    .description = Управление настройками звёздоски

starboard-enable = включить
    .description = Включить звёздоску
    .msg = Звёздоска включена

starboard-disable = выключить
    .description = Выключить звёздоску
    .msg = Звёздоска выключена

starboard-threshold = порог
    .description = Установить количество реакций, необходимое для попадания сообщения в звёздоску
    .value = значение
    .value-description = Минимальное количество реакций
    .msg-invalid = Порог должен быть не меньше 1
    .msg-set = Порог установлен: { $value }

starboard-emoji = эмодзи
    .description = Установить эмодзи, активирующее звёздоску
    .value = значение
    .value-description = Стандартный эмодзи или пользовательский эмодзи сервера
    .msg-invalid = Эмодзи не распознан. Используйте стандартный эмодзи или пользовательский эмодзи сервера.
    .msg-set = Эмодзи установлен: { $value }

starboard-channel = канал
    .description = Установить канал, в который будут отправляться сообщения из звёздоски
    .value = значение
    .value-description = Целевой канал
    .msg-set = Канал установлен: { $value }